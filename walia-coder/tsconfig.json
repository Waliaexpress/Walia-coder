{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": "..",
    "paths": {
      "src/*": ["./src/*"],
      "bun:bundle": ["./walia-coder/stubs/bun-bundle/index.ts"]
    }
  },
  "include": ["../src/**/*", "./build.ts", "./stubs/**/*"]
}
